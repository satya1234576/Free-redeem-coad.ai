"""
secure_full_app.py

Single-file secure Flask app with:
- Embedded encrypted private vault (passphrase required at startup)
- Secure Register/Login (bcrypt)
- Session binding (IP + User-Agent)
- Google reCAPTCHA support (site key in vault)
- Telegram OTP verification (bot sends OTP to user-supplied chat_id)
- Server-side Spin wheel (animated UI) + Scratch card (canvas) — prize chosen server-side and stored encrypted
- Admin panel (admin creds in vault) to view decrypted rewards
- CSRF, rate-limiting, and Talisman CSP headers

Vault passphrase (suggested for this embedded blob):
  K#9t@vL!2hQe%7pZ^sJf

If you want to replace secrets, create your own encrypted blob or modify code to load from .env.
"""

import os, base64, json, getpass, secrets, hashlib, requests, datetime
from functools import wraps
from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.backends import default_backend
from cryptography.fernet import Fernet

# ----------------------------- EMBEDDED ENCRYPTED VAULT -----------------------------
# The blob below contains JSON with keys:
# SECRET_KEY, RECAPTCHA_SECRET, RECAPTCHA_SITEKEY, TELEGRAM_BOT_TOKEN,
# PRIVATE_KEY (for prize encryption), ADMIN_USERNAME, ADMIN_PASSWORD
#
# This blob was encrypted with the passphrase listed above. Keep passphrase safe.
_PRIVATE_BLOB = b"""
gAAAAABngFWuZwbx_FiXHCu5ahLoPt39T6ZYKng7bIReo_CE_iEC5TtjX93FQWtkMeMFqaprfW-fWn9WppWLMevJ9AqWJg_3V2U_0ak5n-B1DU60Zy2B0EoCvSm_AySF7ZQknvevg2P0GQLs9hrpwZRe3xhcXNsN8oZLu_6I4xIV8pgzA9u2MExhUXM-yVVbE4I2or-0kXy3EM1Kh21-Yyp25iMhqlEsxQ==
""".strip()

# constant salt (kept in code). For higher security consider storing salt separately and not in code.
_SALT = b'secure_salt_fixed'

def derive_key(passphrase: str) -> bytes:
    """Derive a Fernet key from a passphrase and fixed salt."""
    kdf = PBKDF2HMAC(
        algorithm=hashes.SHA256(), length=32, salt=_SALT,
        iterations=390000, backend=default_backend()
    )
    return base64.urlsafe_b64encode(kdf.derive(passphrase.encode()))

def load_secrets_from_blob():
    """Prompt for passphrase and decrypt the embedded blob, returning a dict of secrets."""
    passphrase = getpass.getpass("🔑 Enter vault passphrase: ")
    key = derive_key(passphrase)
    f = Fernet(key)
    try:
        dec = f.decrypt(_PRIVATE_BLOB).decode()
        obj = json.loads(dec)
        return obj
    except Exception as e:
        print("❌ Failed to decrypt vault. Wrong passphrase or corrupted blob.")
        raise SystemExit(1)

SECRETS = load_secrets_from_blob()
# required secrets
SECRET_KEY = SECRETS.get("SECRET_KEY")
RECAPTCHA_SECRET = SECRETS.get("RECAPTCHA_SECRET", "")
RECAPTCHA_SITEKEY = SECRETS.get("RECAPTCHA_SITEKEY", "")
TELEGRAM_BOT_TOKEN = SECRETS.get("TELEGRAM_BOT_TOKEN", "")
PRIVATE_KEY = SECRETS.get("PRIVATE_KEY", "")  # used to derive prize encryption
ADMIN_USERNAME = SECRETS.get("ADMIN_USERNAME", "admin")
ADMIN_PASSWORD = SECRETS.get("ADMIN_PASSWORD", "adminpass")

# ----------------------------- FLASK + SECURITY SETUP -----------------------------
from flask import Flask, render_template_string, request, redirect, url_for, flash, session, jsonify
