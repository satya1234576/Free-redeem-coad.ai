app = Flask(__name__)
app.config['SECRET_KEY'] = SECRET_KEY or secrets.token_urlsafe(32)
app.config['SQLALCHEMY_DATABASE_URI'] = 'sqlite:///secure_rewards.sqlite3'
app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False
app.permanent_session_lifetime = datetime.timedelta(minutes=30)

# Security headers
csp = {
    'default-src': ["'self'"],
    'script-src': ["'self'", "https://www.google.com", "https://www.gstatic.com", "'unsafe-inline'"],
    'style-src': ["'self'", "'unsafe-inline'"],
    'img-src': ["'self'", "data:"]
}
Talisman(app, content_security_policy=csp)

db = SQLAlchemy(app)
bcrypt = Bcrypt(app)
csrf = CSRFProtect(app)
csrf.init_app(app)
limiter = Limiter(app, key_func=get_remote_address, app=app, default_limits=["200 per day", "50 per hour"])

# ----------------------------- SECURECORE: prize encryption -----------------------------
# Derive a vault key from PRIVATE_KEY to encrypt prize values in DB
def derive_vault(passphrase: str):
    k = derive_key(passphrase)
    return Fernet(k)

_vault = derive_vault(PRIVATE_KEY or "dev_private_key")
def encrypt_prize(s: str) -> str:
    return _vault.encrypt(s.encode()).decode()
def decrypt_prize(s: str) -> str:
    return _vault.decrypt(s.encode()).decode()

