# ----------------------------- HELPERS -----------------------------
def verify_recaptcha(token: str) -> bool:
    if not RECAPTCHA_SECRET:
        return True
    try:
        r = requests.post("https://www.google.com/recaptcha/api/siteverify", data={'secret': RECAPTCHA_SECRET, 'response': token}, timeout=5)
        return r.json().get('success', False)
    except Exception:
        return False

def session_fingerprint():
    ip = request.remote_addr or ''
    ua = (request.headers.get('User-Agent') or '')[:300]
    return f"{ip}|{ua}"

def require_session_bound():
    fp = session.get('fp')
    if not fp:
        session['fp'] = session_fingerprint()
        return True
    if fp != session_fingerprint():
        session.clear()
        return False
    return True

def login_required(f):
    @wraps(f)
    def wrapper(*a, **k):
        if 'uid' not in session:
            return redirect(url_for('login'))
        if not require_session_bound():
            flash("Session changed — please login again", "danger")
            return redirect(url_for('login'))
        return f(*a, **k)
    return wrapper

# Telegram OTP storage (in-memory short-lived)
_TELE_OTP = {}  # { user_id: {otp:str, chat_id:str, expires:datetime} }

def send_telegram_message(chat_id: str, text: str) -> bool:
    """Send message via Telegram bot token; returns True on (rough) success."""
    if not TELEGRAM_BOT_TOKEN:
        return False
    url = f"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/sendMessage"
    try:
        r = requests.post(url, data={"chat_id": chat_id, "text": text}, timeout=8)
        return r.status_code == 200 or r.json().get('ok', False)
    except Exception:
        return False

